# Copy to .env.codex for local Codex verification.
# Keep .env.codex private; it is ignored by git.

# Option A: a single test-only database URL.
# DATABASE_URL=postgresql://startrader_codex:change-me@localhost:5432/star_trader_test

# Option B: explicit libpq/Rails variables.
# POSTGRES_USER=startrader_codex
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_TEST_DB=star_trader_test

