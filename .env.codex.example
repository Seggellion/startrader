# Copy to .env.codex only when this machine uses a password-based local
# PostgreSQL profile for Codex. Keep .env.codex private; it is ignored by git.
#
# Leave this file unused for the preferred railpress/socket/peer-auth path.
# With no DATABASE_URL, POSTGRES_HOST, or PGHOST set, config/database.yml uses
# libpq defaults: Unix socket, current PostgreSQL role, and star_trader_test.

# Option B1: a single test-only database URL.
# DATABASE_URL=postgresql://startrader_codex:change-me@localhost:5432/star_trader_test

# Option B2: explicit libpq/Rails variables.
# POSTGRES_USER=startrader_codex
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_TEST_DB=star_trader_test
