<div class="bg-white p-6 rounded shadow">
  <div data-controller="modal">
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-2xl font-bold">Commodities</h1>

      <div class="flex gap-2">
        <button data-action="click->modal#open" class="bg-blue-500 text-white px-4 py-2 rounded">
          Import Commodities JSON
        </button>

        <%= link_to 'Add New', new_admin_commodity_path, class: 'bg-blue-500 text-white px-4 py-2 rounded' %>
      </div>
    </div>

    <%= render 'import_modal' %>
  </div>

  <table class="min-w-full bg-white mt-4 border">
    <thead>
      <tr>
        <th class="py-2 px-4 border">Name</th>
        <th class="py-2 px-4 border">Kind</th>
        <th class="py-2 px-4 border">Date</th>
      </tr>
    </thead>
    <tbody>
      <% @commodities.each do |commodity| %>
        <tr>
          <td class="py-2 px-4 border"><%= commodity.name %></td>
          <td class="py-2 px-4 border"><%= commodity.kind %></td>
          <td class="py-2 px-4 border"><%= commodity.created_at.strftime('%Y-%m-%d') %></td>
          <td class="py-2 px-4 border">
            <%= link_to 'Edit', edit_admin_commodity_path(commodity), class: 'text-blue-500 hover:underline' %> |
            <%= link_to 'Delete', admin_commodity_path(commodity), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
