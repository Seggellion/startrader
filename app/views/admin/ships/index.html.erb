<div data-controller="modal search" class="bg-white p-6 rounded shadow">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-bold">Ships</h1>
    
            <div class="flex gap-2">
            <%= button_to 'Delete All Ships', delete_all_admin_ships_path, 
                class: 'bg-red-500 text-white px-4 py-2 rounded', 
                method: :delete, 
                data: { confirm: 'Are you sure you want to delete all Ships? This action cannot be undone.' } %>
                
<div data-controller="modal">
        <button data-action="click->modal#open" class="bg-blue-500 text-white px-4 py-2 rounded">
          Import UEX JSON
        </button>
        <%= render 'import_uex_modal' %>
      </div>

      <div data-controller="modal">
        <button data-action="click->modal#open" class="bg-blue-500 text-white px-4 py-2 rounded">
          Import Star Bitizen JSON
        </button>
        <%= render 'import_starbitizen_modal' %>
      </div>
            
            <%= link_to 'Add New Ship', new_admin_ship_path, class: 'bg-blue-500 text-white px-4 py-2 rounded' %>
            </div>
        </div>

        <div class="mb-4">
            <input type="text" data-search-target="input" data-action="input->search#filter" 
                placeholder="Search ships by name or manufacturer..." 
                class="w-full md:w-1/3 border rounded p-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

 

  <table class="min-w-full bg-white mt-4 border">
    <thead>
      <tr>
        <th class="py-2 px-4 border text-left">Model</th>
        <th class="py-2 px-4 border text-left">Manufacturer</th>
        <th class="py-2 px-4 border text-left">SCU</th>
        <th class="py-2 px-4 border text-left">Crew</th>
        <th class="py-2 px-4 border text-left">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @ships.each do |ship| %>
        <tr data-search-target="item" data-name="<%= [ship.model, ship.name, ship.company_name].compact.join(' ').downcase %>">
          <td class="py-2 px-4 border font-medium"><%= ship.name.presence || ship.model %></td>
          <td class="py-2 px-4 border"><%= ship.company_name %></td>
          <td class="py-2 px-4 border"><%= ship.scu %></td>
          <td class="py-2 px-4 border"><%= ship.crew %></td>
          <td class="py-2 px-4 border">
            <%= link_to 'Edit', edit_admin_ship_path(ship), class: 'text-blue-500 hover:underline' %> |
            <%= link_to 'Delete', admin_ship_path(ship), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
