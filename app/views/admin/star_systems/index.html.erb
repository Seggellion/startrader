<div class="bg-white p-6 rounded shadow">
  <div data-controller="modal">
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-2xl font-bold">Star Systems</h1>

      <div class="flex gap-2">
        <%= button_to 'Delete All Stars', delete_all_admin_star_systems_path,
            class: 'bg-red-500 text-white px-4 py-2 rounded',
            method: :delete,
            data: { confirm: 'Are you sure you want to delete all star systems? This action cannot be undone.' } %>

        <button data-action="click->modal#open" class="bg-blue-500 text-white px-4 py-2 rounded">
          Import Star Systems JSON
        </button>

        <%= link_to 'Add New', new_admin_star_system_path, class: 'bg-blue-500 text-white px-4 py-2 rounded' %>
      </div>
    </div>

    <%= render 'import_modal' %>
  </div>

  <table class="min-w-full bg-white mt-4 border">
    <thead>
      <tr>
        <th class="py-2 px-4 border">Name</th>
        <th class="py-2 px-4 border">Nickname</th>
        <th class="py-2 px-4 border">Code</th>
        <th class="py-2 px-4 border">Date</th>
      </tr>
    </thead>
    <tbody>
      <% @star_systems.each do |star_system| %>
        <tr>
          <td class="py-2 px-4 border"><%= star_system.name %></td>
                    <td class="py-2 px-4 border"><%= star_system.nickname %></td>
          <td class="py-2 px-4 border"><%= star_system.code %></td>
          <td class="py-2 px-4 border"><%= star_system.created_at.strftime('%Y-%m-%d') %></td>
          <td class="py-2 px-4 border">
            <%= link_to 'Edit', edit_admin_star_system_path(star_system), class: 'text-blue-500 hover:underline' %> |
            <%= link_to 'Delete', admin_star_system_path(star_system), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
