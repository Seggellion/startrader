<div class="bg-white p-6 rounded shadow">
  <div data-controller="modal">
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-2xl font-bold">Terminals</h1><small><%= Terminal.count %>/ 675</small>

      <div class="flex gap-2">
        <%= button_to 'Delete All Terminals', delete_all_admin_terminals_path,
          class: 'bg-red-500 text-white px-4 py-2 rounded',
          method: :delete,
          data: { confirm: 'Are you sure you want to delete all terminals? This action cannot be undone.' } %>

        <button data-action="click->modal#open" class="bg-blue-500 text-white px-4 py-2 rounded">
          Import Terminals JSON
        </button>

        <%= link_to 'Add New', new_admin_terminal_path, class: 'bg-blue-500 text-white px-4 py-2 rounded' %>
      </div>
    </div>

    <%= render 'import_modal' %>
  </div>

  <table class="min-w-full bg-white mt-4 border">
    <thead>
      <tr>
        <th class="py-2 px-4 border">Name</th>
        <th class="py-2 px-4 border">Nickname</th>
        <th class="py-2 px-4 border">Parent</th>
        <th class="py-2 px-4 border">Code</th>
        <th class="py-2 px-4 border">Date</th>
      </tr>
    </thead>
    <tbody>
      <% @terminals.each do |terminal| %>
        <tr>
          <td class="py-2 px-4 border"><%= terminal.name %></td>
          <td class="py-2 px-4 border"><%= terminal.nickname %></td>
          
          <td class="py-2 px-4 border"><%= terminal.location&.name %></td>
          <td class="py-2 px-4 border"><%= terminal.code %></td>
          <td class="py-2 px-4 border"><%= terminal.created_at.strftime('%Y-%m-%d') %></td>
          <td class="py-2 px-4 border">
            <%= link_to 'Edit', edit_admin_terminal_path(terminal), class: 'text-blue-500 hover:underline' %> |
            <%= link_to 'Delete', admin_terminal_path(terminal), method: :delete, data: { confirm: 'Are you sure?' }, class: 'text-red-500 hover:underline' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
