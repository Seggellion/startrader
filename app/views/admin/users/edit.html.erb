<%
  page_class = "min-h-screen bg-slate-950 px-4 py-8 text-slate-100 sm:px-6 lg:px-8"
  panel_class = "rounded-lg border border-slate-800 bg-slate-900/80 shadow-xl shadow-black/20"
  label_class = "block text-sm font-semibold text-slate-200"
  input_class = "mt-2 block w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-white placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/20"
  help_class = "mt-1 text-xs text-slate-500"
  role_selected_value = (@user.user_type == 0 || @user.user_type.to_s == "0" || @user.user_type.to_s == "admin") ? 0 : 1
%>

<div class="<%= page_class %>">
  <div class="mx-auto max-w-3xl space-y-6">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <%= link_to "Back to Users", admin_users_path, class: "text-sm font-semibold text-cyan-300 hover:text-cyan-100" %>
        <h1 class="mt-3 text-3xl font-bold text-white">Edit User</h1>
        <p class="mt-2 text-sm text-slate-400">Update safe admin-managed account fields for <%= @user.username.presence || "this user" %>.</p>
      </div>
      <%= link_to "View User", admin_user_path(@user), class: "rounded-md border border-slate-700 px-3 py-2 text-sm font-semibold text-slate-200 transition hover:border-cyan-400/50 hover:bg-cyan-400/10 hover:text-white" %>
    </div>

    <div class="<%= panel_class %> p-5">
      <% if @user.errors.any? %>
        <div class="mb-6 rounded-lg border border-rose-400/30 bg-rose-400/10 p-4 text-sm text-rose-100">
          <p class="font-semibold"><%= pluralize(@user.errors.count, "error") %> prevented this user from being saved.</p>
          <ul class="mt-2 list-disc space-y-1 pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: [:admin, @user], local: true, class: "space-y-6" do |form| %>
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <%= form.label :username, "Username", class: label_class %>
            <%= form.text_field :username, class: input_class, autocomplete: "off" %>
          </div>

          <div>
            <%= form.label :twitch_id, "Twitch ID", class: label_class %>
            <%= form.text_field :twitch_id, class: input_class, autocomplete: "off" %>
          </div>

          <div>
            <%= form.label :user_type, "Role", class: label_class %>
            <%= form.select :user_type, [["Administrator", 0], ["User", 1]], { selected: role_selected_value }, class: input_class %>
          </div>

          <div>
            <%= form.label :country, "Country", class: label_class %>
            <%= form.text_field :country, class: input_class, autocomplete: "country-name" %>
          </div>

          <div>
            <%= form.label :first_name, "First Name", class: label_class %>
            <%= form.text_field :first_name, class: input_class, autocomplete: "given-name" %>
          </div>

          <div>
            <%= form.label :last_name, "Last Name", class: label_class %>
            <%= form.text_field :last_name, class: input_class, autocomplete: "family-name" %>
          </div>

          <div>
            <%= form.label :wallet_balance, "Wallet Balance", class: label_class %>
            <%= form.number_field :wallet_balance, step: "0.01", class: input_class %>
          </div>

          <div>
            <%= form.label :avatar, "Avatar", class: label_class %>
            <% if @user.has_attribute?(:avatar) %>
              <%= form.text_field :avatar, value: @user[:avatar], class: input_class, autocomplete: "off", placeholder: "https://example.com/avatar.png" %>
              <p class="<%= help_class %>">Use a URL, app asset path, or leave blank for the Crafatar fallback.</p>
            <% elsif @user.respond_to?(:avatar) && @user.avatar.respond_to?(:attached?) %>
              <%= form.file_field :avatar, class: input_class %>
              <p class="<%= help_class %>">Upload a replacement avatar image.</p>
            <% else %>
              <p class="mt-2 rounded-md border border-slate-800 bg-slate-950 px-3 py-2 text-sm text-slate-500">Avatar editing is not available for this user record.</p>
            <% end %>
          </div>
        </div>

        <div class="rounded-lg border border-slate-800 bg-slate-950/70 p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Read-only identity fields</p>
          <div class="mt-3 grid gap-4 text-sm sm:grid-cols-2">
            <div>
              <p class="text-slate-500">UID</p>
              <p class="mt-1 font-mono text-slate-300"><%= @user.uid.presence || "-" %></p>
            </div>
            <div>
              <p class="text-slate-500">Provider</p>
              <p class="mt-1 text-slate-300"><%= @user.provider.presence || "-" %></p>
            </div>
          </div>
        </div>

        <div class="flex flex-col-reverse gap-3 border-t border-slate-800 pt-5 sm:flex-row sm:justify-end">
          <%= link_to "Cancel", admin_user_path(@user), class: "rounded-md border border-slate-700 px-4 py-2 text-center text-sm font-semibold text-slate-200 transition hover:border-slate-500 hover:bg-slate-800 hover:text-white" %>
          <%= form.submit "Save User", class: "rounded-md bg-cyan-400 px-4 py-2 text-sm font-bold text-slate-950 transition hover:bg-cyan-300" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
