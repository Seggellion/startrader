<%
  page_class = "min-h-screen bg-slate-950 px-4 py-8 text-slate-100 sm:px-6 lg:px-8"
  panel_class = "rounded-lg border border-slate-800 bg-slate-900/80 shadow-xl shadow-black/20"
  muted_text_class = "text-xs text-slate-400"
  action_class = "rounded-md border border-cyan-400/30 px-3 py-1.5 text-xs font-semibold text-cyan-200 transition hover:border-cyan-300 hover:bg-cyan-400/10 hover:text-white"
  sort_button_class = "rounded-md border border-slate-700 px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-slate-300 transition hover:border-cyan-400/50 hover:bg-cyan-400/10 hover:text-white"

  role_label = lambda do |user|
    raw_role = user.user_type
    raw_role == 0 || raw_role.to_s == "0" || raw_role.to_s == "admin" ? "Administrator" : "User"
  end

  status_badge_class = lambda do |status|
    case status.to_s
    when "in_transit"
      "border border-sky-400/30 bg-sky-400/10 text-sky-200"
    when "docked", "landed", "available"
      "border border-emerald-400/30 bg-emerald-400/10 text-emerald-200"
    when "destroyed", "disabled"
      "border border-rose-400/30 bg-rose-400/10 text-rose-200"
    else
      "border border-slate-600 bg-slate-800 text-slate-300"
    end
  end

  avatar_source = lambda do |user|
    if user.respond_to?(:avatar) && user.avatar.respond_to?(:attached?) && user.avatar.attached?
      url_for(user.avatar)
    else
      avatar_value = user.has_attribute?(:avatar) ? user[:avatar].to_s : ""
      if avatar_value.present? && (avatar_value.match?(/\Ahttps?:\/\//) || avatar_value.start_with?("/") || avatar_value.match?(/\.(png|jpg|jpeg|gif|webp|svg)\z/i))
        avatar_value
      else
        "https://crafatar.com/avatars/#{user.uid}?size=128&overlay"
      end
    end
  end
%>

<div class="<%= page_class %>">
  <div class="mx-auto max-w-7xl space-y-6" data-controller="search sort">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-cyan-300">Admin</p>
        <h1 class="mt-2 text-3xl font-bold text-white">Users</h1>
        <p class="mt-2 max-w-3xl text-sm text-slate-400">Manage StarTrader player accounts, wallets, roles, and active ships.</p>
      </div>

      <div class="<%= panel_class %> px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Rendered Users</p>
        <p class="mt-1 text-2xl font-bold text-white"><span data-search-target="count"><%= @users.size %></span></p>
      </div>
    </div>

    <div class="<%= panel_class %>">
      <div class="space-y-4 border-b border-slate-800 p-4">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
          <div class="w-full max-w-xl">
            <label for="admin-users-search" class="sr-only">Search users</label>
            <input
              id="admin-users-search"
              type="search"
              placeholder="Search users, wallets, ships, locations..."
              class="w-full rounded-md border border-slate-700 bg-slate-950/80 px-4 py-2.5 text-sm text-white placeholder:text-slate-500 focus:border-cyan-400 focus:outline-none focus:ring-2 focus:ring-cyan-400/20"
              data-search-target="input"
              data-action="input->search#filter">
          </div>

          <div class="flex flex-wrap gap-2">
            <button type="button" class="<%= sort_button_class %>" data-action="click->sort#sort" data-sort-key-param="username">User</button>
            <button type="button" class="<%= sort_button_class %>" data-action="click->sort#sort" data-sort-key-param="active-ship">Ship</button>
            <button type="button" class="<%= sort_button_class %>" data-action="click->sort#sort" data-sort-key-param="wallet-balance">Wallet</button>
            <button type="button" class="<%= sort_button_class %>" data-action="click->sort#sort" data-sort-key-param="role">Role</button>
            <button type="button" class="<%= sort_button_class %>" data-action="click->sort#sort" data-sort-key-param="last-login">Last Login</button>
          </div>
        </div>

        <div class="hidden grid-cols-[minmax(0,2fr)_minmax(0,1.7fr)_minmax(7rem,0.7fr)_minmax(6rem,0.6fr)_minmax(7rem,0.8fr)_minmax(8rem,0.7fr)] gap-4 px-4 text-xs font-semibold uppercase tracking-wide text-slate-500 lg:grid">
          <div>User</div>
          <div>Active Ship</div>
          <div>Wallet</div>
          <div>Role</div>
          <div>Last Login</div>
          <div class="text-right">Actions</div>
        </div>
      </div>

      <div class="divide-y divide-slate-800" data-sort-target="container">
        <% @users.each do |user| %>
          <%
            active_ship = user.active_ship
            active_travel = active_ship&.active_travel
            destination_name = active_travel&.to_location&.name
            ship_name = active_ship&.ship&.model.presence || active_ship&.ship_slug.presence || (active_ship ? "Unknown ship" : "No active ship")
            ship_slug = active_ship&.ship_slug
            status = active_ship&.status.presence || "No active ship"
            location_text = if active_ship.blank?
              "No active ship"
            elsif active_ship.status.to_s == "in_transit"
              ["To #{destination_name.presence || "Unknown destination"}", active_travel&.arrival_tick.present? ? "tick #{active_travel.arrival_tick}" : nil].compact.join(" - ")
            else
              active_ship.location_name.presence || "Unknown location"
            end
            role = role_label.call(user)
            wallet_value = user.wallet_balance || 0
            last_login_sort = user.last_login&.to_i || 0
            real_name = [user.first_name, user.last_name].compact_blank.join(" ")
            last_login_label = user.last_login ? user.last_login.strftime("%b %d, %Y") : "Never"
            search_text = [
              user.username,
              user.uid,
              user.provider,
              user.country,
              role,
              wallet_value,
              ship_name,
              ship_slug,
              status,
              active_ship&.location_name,
              destination_name,
              last_login_label,
              user.created_at&.strftime("%b %d, %Y")
            ].compact.join(" ")
          %>

          <article
            class="grid gap-4 p-4 transition hover:bg-slate-800/50 lg:grid-cols-[minmax(0,2fr)_minmax(0,1.7fr)_minmax(7rem,0.7fr)_minmax(6rem,0.6fr)_minmax(7rem,0.8fr)_minmax(8rem,0.7fr)] lg:items-center"
            data-search-target="item"
            data-sort-target="item"
            data-search-text="<%= search_text.downcase %>"
            data-sort-username="<%= user.username.to_s.downcase %>"
            data-sort-active-ship="<%= ship_name.downcase %>"
            data-sort-wallet-balance="<%= wallet_value %>"
            data-sort-role="<%= role.downcase %>"
            data-sort-last-login="<%= last_login_sort %>">
            <div class="min-w-0">
              <%= link_to admin_user_path(user), class: "group flex min-w-0 items-center gap-3 rounded-md outline-none focus:ring-2 focus:ring-cyan-400/40" do %>
                <%= image_tag avatar_source.call(user), alt: "#{user.username.presence || "User"} avatar", class: "h-11 w-11 shrink-0 rounded-full border border-slate-700 bg-slate-800 object-cover" %>
                <span class="min-w-0">
                  <span class="block truncate font-semibold text-white group-hover:text-cyan-200"><%= user.username.presence || "Unnamed user" %></span>
                  <span class="block truncate text-sm text-slate-400"><%= real_name.presence || "No profile name" %></span>
                  <span class="block truncate font-mono text-xs text-slate-500"><%= user.uid.presence || "No UID" %></span>
                </span>
              <% end %>
            </div>

            <div class="min-w-0">
              <p class="truncate text-sm font-semibold text-slate-100"><%= ship_name %></p>
              <div class="mt-1 flex flex-wrap items-center gap-2">
                <span class="inline-flex rounded-full px-2 py-0.5 text-xs font-semibold <%= status_badge_class.call(active_ship&.status) %>"><%= status.to_s.titleize %></span>
                <span class="min-w-0 truncate text-xs text-slate-400"><%= location_text %></span>
              </div>
            </div>

            <div>
              <p class="<%= muted_text_class %> lg:hidden">Wallet</p>
              <p class="font-semibold text-emerald-200"><%= number_to_currency(wallet_value) %></p>
            </div>

            <div>
              <p class="<%= muted_text_class %> lg:hidden">Role</p>
              <% if role == "Administrator" %>
                <span class="inline-flex rounded-full border border-amber-300/30 bg-amber-300/10 px-2.5 py-1 text-xs font-semibold text-amber-200">Administrator</span>
              <% else %>
                <span class="inline-flex rounded-full border border-slate-600 bg-slate-800 px-2.5 py-1 text-xs font-semibold text-slate-300">User</span>
              <% end %>
            </div>

            <div>
              <p class="<%= muted_text_class %> lg:hidden">Last Login</p>
              <p class="text-sm text-slate-300"><%= last_login_label %></p>
            </div>

            <div class="flex flex-wrap gap-2 lg:justify-end">
              <%= link_to "Show", admin_user_path(user), class: action_class %>
              <%= link_to "Edit", edit_admin_user_path(user), class: action_class %>
            </div>
          </article>
        <% end %>
      </div>
    </div>
  </div>
</div>
