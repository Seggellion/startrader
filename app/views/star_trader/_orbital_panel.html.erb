<section class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/90">
  <div class="border-b border-zinc-800 p-4">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300">Orbital Simulator</p>
    <h2 class="mt-1 text-lg font-semibold text-white">System Map</h2>
  </div>

  <div class="relative h-[360px] bg-black sm:h-[460px] lg:h-[520px]" data-controller="star-system" data-action="star-trader:focus-location@window->star-system#focusLocation">
    <div class="absolute left-3 top-3 z-10 flex gap-2">
      <button type="button" class="rounded-md border border-zinc-700 bg-zinc-950/80 px-3 py-2 text-xs font-semibold text-zinc-100 hover:border-cyan-400" data-action="star-system#selectStarSystem" data-star-system-name="Stanton">Stanton</button>
      <button type="button" class="rounded-md border border-zinc-700 bg-zinc-950/80 px-3 py-2 text-xs font-semibold text-zinc-100 hover:border-cyan-400" data-action="star-system#selectStarSystem" data-star-system-name="Pyro">Pyro</button>
    </div>
  </div>

  <%= render "selected_location", facility: selected_facility %>
</section>
