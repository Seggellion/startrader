<header class="rounded-lg border border-zinc-800 bg-zinc-900/90 p-4 shadow-2xl shadow-black/30">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.25em] text-cyan-300">StarBitizen Trade Network</p>
      <h1 class="mt-1 text-3xl font-bold text-white sm:text-4xl">Star Trader</h1>
    </div>

    <dl id="market_status" class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-4 lg:min-w-[720px]">
      <div class="rounded-md border border-zinc-800 bg-zinc-950/70 p-3">
        <dt class="text-xs uppercase text-zinc-400">Tick</dt>
        <dd class="mt-1 font-mono text-lg text-amber-200"><%= @current_tick.current_tick %></dd>
      </div>
      <div class="rounded-md border border-zinc-800 bg-zinc-950/70 p-3">
        <dt class="text-xs uppercase text-zinc-400">System</dt>
        <dd class="mt-1 truncate font-semibold text-zinc-100"><%= @active_system %></dd>
      </div>
      <div class="rounded-md border border-zinc-800 bg-zinc-950/70 p-3">
        <dt class="text-xs uppercase text-zinc-400">Market update</dt>
        <dd class="mt-1 font-mono text-sm text-zinc-200"><%= @last_market_update_at ? time_ago_in_words(@last_market_update_at) + " ago" : "Pending" %></dd>
      </div>
      <div class="rounded-md border border-zinc-800 bg-zinc-950/70 p-3">
        <dt class="text-xs uppercase text-zinc-400">Tracked sites</dt>
        <dd class="mt-1 font-mono text-lg text-emerald-200"><%= market_quantity(@tracked_locations_count) %></dd>
      </div>
    </dl>
  </div>

  <div class="mt-3 inline-flex items-center gap-2 rounded-full border border-cyan-400/30 bg-cyan-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-cyan-100">
    <span class="h-2 w-2 rounded-full bg-cyan-300" aria-hidden="true"></span>
    Live-ready via Turbo Streams
  </div>
</header>
