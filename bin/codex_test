#!/usr/bin/env bash
set -u

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

FAILURE_CLASS=""
TEST_ARGS=("$@")

info() {
  printf "\n== %s ==\n" "$1"
}

fail() {
  FAILURE_CLASS="$1"
  shift
  printf "\n[%s]\n" "$FAILURE_CLASS" >&2
  printf "%s\n" "$*" >&2
  exit 1
}

run_capture() {
  local label="$1"
  shift
  local log_file
  log_file="$(mktemp "${TMPDIR:-/tmp}/codex-test.XXXXXX")"

  info "$label"
  printf "+ %s\n" "$*"
  if "$@" >"$log_file" 2>&1; then
    cat "$log_file"
    rm -f "$log_file"
    return 0
  fi

  cat "$log_file" >&2
  classify_failure "$log_file"
  rm -f "$log_file"
  return 1
}

classify_failure() {
  local log_file="$1"

  if grep -Eiq "Ruby version|RubyVersionMismatch|rbenv: version|rbenv:.*not installed|bundle: command not found|Bundler::" "$log_file"; then
    FAILURE_CLASS="Ruby/toolchain failure"
  elif grep -Eiq "role .* does not exist|no password supplied|password authentication failed|Peer authentication failed|fe_sendauth" "$log_file"; then
    FAILURE_CLASS="Postgres role/authentication failure"
  elif grep -Eiq "No such file or directory|could not connect|Connection refused|server closed the connection|pg_isready" "$log_file"; then
    FAILURE_CLASS="Postgres service/socket failure"
  elif grep -Eiq "permission denied|not in railpress|newgrp railpress" "$log_file"; then
    FAILURE_CLASS="Linux user/group membership failure"
  elif grep -Eiq "ActiveRecord::|PG::|db:prepare|database .* does not exist|schema" "$log_file"; then
    FAILURE_CLASS="Rails database preparation failure"
  else
    FAILURE_CLASS="Actual application test failure"
  fi
}

required_ruby() {
  awk -F'"' '/^ruby / { print $2; exit }' Gemfile
}

load_codex_env() {
  local env_file="${CODEX_ENV_FILE:-.env.codex}"

  if [ -f "$env_file" ]; then
    info "Loading $env_file"
    set -a
    # shellcheck disable=SC1090
    . "$env_file"
    set +a
  fi
}

check_ruby() {
  local expected actual ruby_version_file
  expected="$(required_ruby)"
  ruby_version_file="$(sed 's/^ruby-//' .ruby-version 2>/dev/null || true)"

  info "Ruby"
  printf "Gemfile ruby: %s\n" "$expected"
  printf ".ruby-version: %s\n" "${ruby_version_file:-missing}"
  if [ "${ruby_version_file:-}" != "$expected" ]; then
    fail "Ruby/toolchain failure" ".ruby-version does not match Gemfile. Expected $expected."
  fi

  run_capture "Ruby diagnostics" bin/codex_exec --ruby-diagnostics || {
    fail "$FAILURE_CLASS" "Could not activate the project Ruby. Install it with: rbenv install $expected"
  }

  if ! actual="$(bin/codex_exec ruby -e 'print RUBY_VERSION' 2>&1)"; then
    printf "%s\n" "$actual" >&2
    fail "Ruby/toolchain failure" "Could not run Ruby $expected through bin/codex_exec."
  fi

  printf "Active ruby: %s\n" "$actual"
  if [ "$actual" != "$expected" ]; then
    fail "Ruby/toolchain failure" "Active Ruby is $actual, but this app requires $expected."
  fi
}

check_user_and_groups() {
  info "Linux user and groups"
  whoami
  id
  groups

  if getent group railpress >/dev/null 2>&1; then
    getent group railpress
    if ! id -nG | tr ' ' '\n' | grep -qx railpress; then
      fail "Linux user/group membership failure" "The current Linux user is not in the railpress group. Run: sudo usermod -aG railpress $(whoami), then restart WSL or run: newgrp railpress."
    fi
  else
    printf "railpress group was not found; continuing because explicit database credentials may be in use.\n"
  fi
}

db_profile_summary() {
  info "Database profile"
  if [ -n "${DATABASE_URL:-}" ]; then
    printf "Using DATABASE_URL for test database configuration.\n"
  elif [ -n "${POSTGRES_USER:-${PGUSER:-}}" ] || [ -n "${POSTGRES_PASSWORD:-${PGPASSWORD:-}}" ] || [ -n "${POSTGRES_HOST:-${PGHOST:-}}" ]; then
    printf "Using explicit POSTGRES_*/PG* variables for test database configuration.\n"
    printf "Test database: %s\n" "${POSTGRES_TEST_DB:-star_trader_test}"
  else
    printf "Using config/database.yml local defaults: Unix socket, current PostgreSQL role, database star_trader_test.\n"
  fi
}

check_postgres() {
  run_capture "Codex database doctor" bin/codex_db_doctor --require-connection || {
    fail "$FAILURE_CLASS" "Codex database access is not ready. Fix the reported Rails test database profile before Rails tests can run."
  }
}

run_bundle_install() {
  run_capture "Bundle install" bin/codex_exec bundle install || fail "$FAILURE_CLASS" "bundle install failed."
}

prepare_database() {
  run_capture "Rails test database prepare" env RAILS_ENV=test bin/codex_exec bundle exec rails db:prepare || {
    fail "$FAILURE_CLASS" "Rails could not prepare the test database."
  }
}

run_tests() {
  if [ "${#TEST_ARGS[@]}" -gt 0 ]; then
    run_capture "Rails targeted test suite" env RAILS_ENV=test bin/codex_exec bundle exec rails test "${TEST_ARGS[@]}" || {
      fail "$FAILURE_CLASS" "Rails tests did not pass."
    }
    return
  fi

  run_capture "Rails test suite" env RAILS_ENV=test bin/codex_exec bundle exec rails test || {
    fail "$FAILURE_CLASS" "Rails tests did not pass."
  }
}

if [ "${1:-}" = "--ruby-diagnostics" ]; then
  bin/codex_exec --ruby-diagnostics
  exit $?
fi

load_codex_env
check_ruby
check_user_and_groups
db_profile_summary
check_postgres
run_bundle_install
prepare_database
run_tests

info "Result"
printf "Codex local verification passed.\n"
